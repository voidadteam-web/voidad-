# Supabase — from https://supabase.com/dashboard/project/_/settings/api
# Must include https:// (or host only — code adds https automatically)
NEXT_PUBLIC_SUPABASE_URL=https://nehewgoinyxxjzjitpea.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Required for signup device/network checks (Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional salt for hashing visitor IP (router/network identity)
NETWORK_HASH_SALT=voidad-network-v1

# VoidAd DNS (router / home Wi‑Fi control)
NEXT_PUBLIC_VOIDAD_DNS_PRIMARY=127.0.0.1
NEXT_PUBLIC_VOIDAD_DNS_SECONDARY=1.1.1.1
NEXT_PUBLIC_VOIDAD_DOH_HOST=dns.voidad.com
VOIDAD_DNS_SYNC_KEY=change-me-to-a-long-random-secret
VOIDAD_REPORT_URL=http://localhost:3000/api/dns/report
