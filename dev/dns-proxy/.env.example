# Copy to .env and fill in (run.sh loads this automatically)
# Use voidad.com when testing with production dashboard account:
VOIDAD_SYNC_URL=https://voidad.com/api/dns/tenants
VOIDAD_REPORT_URL=https://voidad.com/api/dns/report

# Home LAN mode — Mac acts as DNS for entire Wi‑Fi (phones, TV, etc.)
# VOIDAD_LAN_MODE=true
# VOIDAD_MAX_MODE=true
# VOIDAD_DNS_HOST=auto
# VOIDAD_ALLOWED_CIDRS=127.0.0.0/8,192.168.0.0/24
# VOIDAD_UPSTREAM_DNS_FALLBACK=1.1.1.1

# Or for local dashboard:
# VOIDAD_SYNC_URL=http://127.0.0.1:3000/api/dns/tenants
# VOIDAD_REPORT_URL=http://127.0.0.1:3000/api/dns/report

# Must match VOIDAD_DNS_SYNC_KEY on Vercel / .env.local
VOIDAD_DNS_SYNC_KEY=change-me-to-a-long-random-secret
